APP_ENV=development
LOG_LEVEL=INFO

# Provider selection. Ingest requires model-backed providers.
REASONING_MODEL_PROVIDER=huggingface
EMBEDDING_MODEL_PROVIDER=huggingface
RERANKER_MODEL_PROVIDER=huggingface

# PostgreSQL generated-content store.
POSTGRES_MODE=postgres
POSTGRES_DSN=postgresql://marag:pwd@127.0.0.1:5432/marag

# Neo4j graph projection.
NEO4J_MODE=neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Azure OpenAI reasoning / optional embeddings.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_REASONING_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Hugging Face local model stack.
# HF_TOKEN is preferred. HUGGINGFACE_TOKEN and HUGGING_FACE_HUB_TOKEN are
# still accepted for backward compatibility.
HF_TOKEN=
HUGGINGFACE_TOKEN=
HUGGINGFACE_REASONING_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct
HUGGINGFACE_EMBEDDING_MODEL=BAAI/bge-m3
HUGGINGFACE_RERANKER_MODEL=BAAI/bge-reranker-base
HUGGINGFACE_OFFLINE=false
HUGGINGFACE_MAX_NEW_TOKENS=4096
DISCOVERY_BATCH_SIZE=1
LOG_LLM_RESPONSES=true

# Legacy alias accepted when DISCOVERY_BATCH_SIZE is unset.
HUGGINGFACE_DISCOVERY_BATCH_SIZE=

# Optional stage-4 retrieval/generation tuning.
TEST_SCENARIO_TOP_K=4
TEST_SCENARIO_DENSE_K=8
TEST_SCENARIO_SPARSE_K=8
TEST_SCENARIO_NEIGHBOR_WINDOW=1
TEST_SCENARIO_MAX_NEW_TOKENS=

# Optional path overrides
# PROJECT_ROOT=
# GLOBAL_CACHE_DIR=.global_cache
# DOCUMENTS_INBOX_DIR=documents/inbox
# GENERATED_REQUIREMENTS_DIR=generated
# CHROMA_PERSIST_DIR=runtime/databases/chroma
# RUNTIME_STAGING_DIR=runtime/staging
# RUNTIME_LOGS_DIR=runtime/logs
# RUNTIME_LOCKS_DIR=runtime/locks

# PostgreSQL Windows service automation
MARAG_POSTGRES_AUTO_START=true
MARAG_POSTGRES_SERVICE_NAME=postgresql-x64-18
MARAG_POSTGRES_HOST=127.0.0.1
MARAG_POSTGRES_PORT=5432
MARAG_ALLOW_SERVICE_STOP=false
MARAG_POSTGRES_ALLOW_STOP=false

# Neo4j Desktop/DBMS automation
MARAG_NEO4J_AUTO_START=true
MARAG_NEO4J_START_MODE=desktop_dbms
NEO4J_DBMS_HOME=
NEO4J_JAVA_HOME=
MARAG_NEO4J_HTTP_PORT=7474
MARAG_NEO4J_BOLT_PORT=7687
