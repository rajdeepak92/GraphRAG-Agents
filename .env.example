APP_ENV=development
LOG_LEVEL=DEBUG

# Stage-specific provider selection.
REASONING_MODEL_PROVIDER=huggingface
EMBEDDING_MODEL_PROVIDER=huggingface
RERANKER_MODEL_PROVIDER=huggingface

# PostgreSQL application and LangGraph checkpoint store.
POSTGRES_MODE=postgres
POSTGRES_DSN=postgresql://marag:marag@127.0.0.1:5432/marag

# Neo4j project-scoped graph store.
NEO4J_MODE=neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Azure OpenAI reasoning and embeddings.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_REASONING_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Private Hugging Face reasoning, embeddings, and reranking.
HF_TOKEN=
HUGGINGFACE_REASONING_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct
HUGGINGFACE_EMBEDDING_MODEL=BAAI/bge-m3
HUGGINGFACE_RERANKER_MODEL=BAAI/bge-reranker-base
HUGGINGFACE_OFFLINE=false
HUGGINGFACE_MAX_NEW_TOKENS=4096
LOG_LLM_RESPONSES=false

# Bounded execution.
WORKFLOW_CONCURRENCY=1
WORKFLOW_TIMEOUT_SECONDS=120
TRANSIENT_MAX_ATTEMPTS=2

# Current-run hybrid retrieval.
RETRIEVAL_TOP_K=6
RETRIEVAL_VECTOR_K=12
RETRIEVAL_GRAPH_K=12
RETRIEVAL_MAX_HOPS=2
RETRIEVAL_TOKEN_BUDGET=6000

# Optional path overrides.
# PROJECT_ROOT=
# GENERATED_DIR=generated
# CHROMA_PERSIST_DIR=runtime/databases/chroma
# RUNTIME_STAGING_DIR=runtime/staging
# RUNTIME_LOGS_DIR=runtime/logs
