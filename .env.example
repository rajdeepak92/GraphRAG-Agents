APP_ENV=development
LOG_LEVEL=INFO

# Provider selection. Use local defaults for offline smoke checks.
REASONING_MODEL_PROVIDER=local_heuristic
EMBEDDING_MODEL_PROVIDER=local_hash
RERANKER_MODEL_PROVIDER=none

# PostgreSQL generated-content store. Set POSTGRES_MODE=postgres for the real DB.
POSTGRES_MODE=local_json
POSTGRES_DSN=postgresql://marag:<password>@127.0.0.1:5432/marag

# Neo4j graph projection. Set NEO4J_MODE=neo4j for the real graph.
NEO4J_MODE=local_json
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Azure OpenAI reasoning / optional embeddings
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_REASONING_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Hugging Face local embeddings / optional local reasoning
HUGGINGFACE_TOKEN=
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HUGGINGFACE_REASONING_MODEL=
HUGGINGFACE_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
HUGGINGFACE_OFFLINE=false

# Optional path overrides
# PROJECT_ROOT=
# GLOBAL_CACHE_DIR=.global_cache
# DOCUMENTS_INBOX_DIR=documents/inbox
# GENERATED_REQUIREMENTS_DIR=generated/inbox
# CHROMA_PERSIST_DIR=runtime/databases/chroma
# RUNTIME_STAGING_DIR=runtime/staging
# RUNTIME_LOGS_DIR=runtime/logs
# RUNTIME_LOCKS_DIR=runtime/locks
