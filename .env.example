# Multi-Agentic Knowledge-Graph RAG
# Copy this file to .env for local development.
# Never commit .env.

APP_ENV=development
LOG_LEVEL=INFO

# Provider selection
REASONING_LLM_PROVIDER=azure_openai
EMBEDDING_PROVIDER=huggingface
VECTOR_STORE_PROVIDER=chroma_local
GRAPH_STORE_PROVIDER=neo4j_local

# PostgreSQL canonical registry
POSTGRES_DSN=postgresql+asyncpg://marag:<password>@127.0.0.1:5432/marag

# Neo4j graph projection
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=9861494886
NEO4J_DATABASE=neo4j

# Azure OpenAI reasoning / optional embeddings
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_REASONING_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Hugging Face local embeddings / optional local reasoning
HUGGINGFACE_TOKEN=
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HUGGINGFACE_REASONING_MODEL=
HUGGINGFACE_OFFLINE=false

# Optional path overrides
# PROJECT_ROOT=
# GLOBAL_CACHE_DIR=.global_cache
# DOCUMENTS_INBOX_DIR=documents/inbox
# GENERATED_ARTIFACTS_DIR=generated_artifacts
# CHROMA_PERSIST_DIR=runtime/databases/chroma
# RUNTIME_STAGING_DIR=runtime/staging
# RUNTIME_LOGS_DIR=runtime/logs
# RUNTIME_LOCKS_DIR=runtime/locks